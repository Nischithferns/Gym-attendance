# ──────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in real values.
# On Vercel, add these same keys under Project Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────

# Supabase — from your Supabase project: Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service role key (SERVER-ONLY, never exposed to the browser). Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Coach/owner passcode for viewing attendance
COACH_PIN=1234

# Gym branding + timezone (server side)
GYM_NAME=My Gym
GYM_TZ=Asia/Kolkata

# Public copies used by the browser (client pages). Keep in sync with the two above.
NEXT_PUBLIC_GYM_NAME=My Gym
NEXT_PUBLIC_GYM_TZ=Asia/Kolkata

# Minimum minutes between check-in and check-out (prevents accidental
# double-scans from instantly marking "Out"). Set to 0 to disable.
MIN_GAP_MINUTES=1
